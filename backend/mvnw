#!/bin/sh
# Maven Wrapper script for Unix

MAVEN_PROJECTBASEDIR="$(cd "$(dirname "$0")" && pwd)"

if [ ! -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" ]; then
    echo "Downloading Maven Wrapper JAR..."
    mkdir -p "$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
    curl -fsSL https://repo.maven.apache.org/maven2/io/takari/maven-wrapper/0.5.6/maven-wrapper-0.5.6.jar -o "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
fi

java -cp "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" org.apache.maven.wrapper.MavenWrapperMain "$@"
